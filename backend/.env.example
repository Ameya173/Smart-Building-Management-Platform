# Database
MONGO_URI=mongodb://localhost:27017/digital-twin-ai

# JWT Secrets
JWT_SECRET=your_jwt_access_secret_key_here_change_in_prod
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_prod
JWT_REFRESH_EXPIRES_IN=30d

# Email Configuration (for OTP & Password Reset)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-or-email-password
EMAIL_FROM=no-reply@digitaltwin.ai

# Frontend URL (for CORS and password reset links)
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000
